{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-claude-auth@latest"],
  "permission": {
    "bash": {
      "*": "ask",
      "rm *": "deny",
      "git *": "allow",
      "git commit *": "ask",
      "git push *": "deny",
      "grep *": "allow"
    },
    "edit": {
      "*": "ask"
    },
    "external_directory": {
      "~/dev/**": "allow"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "*.sec*": "deny"
    }
  }
}
