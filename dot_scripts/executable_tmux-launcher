#!/usr/bin/env bash
set -eu

items="dotfiles
lazygit
lazydocker
k9s
btop
"

chosen=$(printf "$items" | fzf --prompt="  Launch: " --height=100% --border=none)

[ -z "$chosen" ] && exit 0

case "$chosen" in
  dotfiles)   tmux new-window -n dotfiles   -c "$HOME/.local/share/chezmoi" chezmoi edit ;;
  lazygit)    tmux new-window -n lazygit    -c "#{pane_current_path}" lazygit ;;
  lazydocker) tmux new-window -n lazydocker lazydocker ;;
  k9s)        tmux new-window -n k9s k9s ;;
  btop)       tmux new-window -n btop btop ;;
esac
