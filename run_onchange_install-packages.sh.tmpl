#!/usr/bin/env bash
# chezmoi: run_onchange — reruns automatically when this file changes
set -euo pipefail

{{ if eq .chezmoi.os "darwin" -}}
# =============================================================================
# macOS — Homebrew
# =============================================================================

if ! command -v brew &>/dev/null; then
  echo "Installing Homebrew..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

brew update

# --- Core CLI tools ---
brew install \
  neovim \
  tmux \
  fzf \
  bat \
  eza \
  git \
  starship \
  lazygit \
  lazydocker \
  yazi \
  btop \
  watchexec \
  fish \
  zsh \
  ripgrep \
  direnv \
  aichat \
  k9s

# --- Dev runtimes ---
brew install \
  go \
  rustup \
  node \
  python \
  poetry \
  colima \
  docker \
  docker-compose

# --- macOS-specific tools ---
brew install \
  koekeishiya/formulae/yabai \
  koekeishiya/formulae/skhd

# --- GUI apps (Cask) ---
brew install --cask \
  vivaldi \
  discord \
  obsidian

{{ else if eq .chezmoi.os "linux" -}}
# =============================================================================
# Linux
# =============================================================================

{{ if eq .machineType "laptop" -}}
# ==========================================================================
# Arch Linux — Laptop
# ==========================================================================

# Ensure yay is available
if ! command -v yay &>/dev/null; then
  echo "Installing yay (AUR helper)..."
  sudo pacman -S --needed --noconfirm git base-devel
  tmpdir=$(mktemp -d)
  git clone https://aur.archlinux.org/yay.git "$tmpdir/yay"
  (cd "$tmpdir/yay" && makepkg -si --noconfirm)
  rm -rf "$tmpdir"
fi

# --- Core CLI tools ---
yay -S --needed --noconfirm \
  neovim \
  tmux \
  fzf \
  bat \
  eza \
  git \
  starship \
  lazygit \
  lazydocker \
  yazi \
  btop \
  watchexec \
  fish \
  zsh \
  ripgrep \
  direnv \
  aichat \
  k9s

# --- Dev runtimes ---
yay -S --needed --noconfirm \
  go \
  rustup \
  nodejs \
  npm \
  python \
  python-poetry \
  docker \
  docker-compose

# --- Wayland / WM stack (laptop-only) ---
yay -S --needed --noconfirm \
  sway \
  waybar \
  wmenu \
  wlsunset \
  autotiling \
  xwaylandvideobridge \
  wireplumber \
  pipewire \
  pipewire-pulse \
  helvum \
  blueman \
  kitty \
  emptty \
  brightnessctl \
  playerctl

# --- GUI apps ---
yay -S --needed --noconfirm \
  vivaldi \
  discord \
  obsidian

# Enable services
sudo systemctl enable --now docker
sudo usermod -aG docker "$USER"

{{ else -}}
# ==========================================================================
# Debian — Devbox VM
# ==========================================================================

export DEBIAN_FRONTEND=noninteractive
sudo apt-get update -qq

# --- Core dependencies ---
sudo apt-get install -y --no-install-recommends \
  curl \
  wget \
  git \
  build-essential \
  ca-certificates \
  gnupg \
  lsb-release \
  unzip \
  zsh \
  fish \
  ripgrep \
  direnv \
  btop \
  tmux \
  fzf

# --- Packages available in apt ---
sudo apt-get install -y --no-install-recommends \
  bat \
  fd-find \
  python3 \
  python3-pip \
  python3-venv \
  nodejs \
  npm

# bat is installed as batcat on Debian — symlink to bat
if command -v batcat &>/dev/null && ! command -v bat &>/dev/null; then
  mkdir -p ~/.local/bin
  ln -sf "$(command -v batcat)" ~/.local/bin/bat
fi

# --- Neovim (AppImage, latest stable) ---
if ! command -v nvim &>/dev/null; then
  curl -Lo /tmp/nvim.appimage \
    https://github.com/neovim/neovim/releases/latest/download/nvim-linux-x86_64.appimage
  chmod +x /tmp/nvim.appimage
  sudo mv /tmp/nvim.appimage /usr/local/bin/nvim
fi

# --- Starship ---
if ! command -v starship &>/dev/null; then
  curl -sS https://starship.rs/install.sh | sh -s -- --yes
fi

# --- eza ---
if ! command -v eza &>/dev/null; then
  sudo mkdir -p /etc/apt/keyrings
  wget -qO- https://raw.githubusercontent.com/eza-community/eza/main/deb.asc \
    | sudo gpg --dearmor -o /etc/apt/keyrings/gierens.gpg
  echo "deb [signed-by=/etc/apt/keyrings/gierens.gpg] http://deb.gierens.de stable main" \
    | sudo tee /etc/apt/sources.list.d/gierens.list
  sudo apt-get update -qq
  sudo apt-get install -y eza
fi

# --- lazygit ---
if ! command -v lazygit &>/dev/null; then
  lg_version=$(curl -sL https://api.github.com/repos/jesseduffield/lazygit/releases/latest \
    | grep '"tag_name"' | cut -d'"' -f4 | sed 's/v//')
  curl -Lo /tmp/lazygit.tar.gz \
    "https://github.com/jesseduffield/lazygit/releases/latest/download/lazygit_${lg_version}_Linux_x86_64.tar.gz"
  tar -xf /tmp/lazygit.tar.gz -C /tmp lazygit
  sudo install /tmp/lazygit /usr/local/bin
fi

# --- yazi ---
if ! command -v yazi &>/dev/null; then
  yazi_url=$(curl -sL https://api.github.com/repos/sxyazi/yazi/releases/latest \
    | grep "browser_download_url.*yazi-x86_64-unknown-linux-musl.tar.gz" \
    | cut -d'"' -f4)
  curl -Lo /tmp/yazi.tar.gz "$yazi_url"
  tar -xf /tmp/yazi.tar.gz -C /tmp
  sudo install /tmp/yazi-x86_64-unknown-linux-musl/yazi /usr/local/bin
fi

# --- watchexec ---
if ! command -v watchexec &>/dev/null; then
  we_url=$(curl -sL https://api.github.com/repos/watchexec/watchexec/releases/latest \
    | grep "browser_download_url.*watchexec-.*-x86_64-unknown-linux-musl.tar.xz" \
    | grep -v "cli" \
    | head -1 | cut -d'"' -f4)
  curl -Lo /tmp/watchexec.tar.xz "$we_url"
  tar -xf /tmp/watchexec.tar.xz -C /tmp
  sudo install /tmp/watchexec-*/watchexec /usr/local/bin
fi

# --- Go ---
if ! command -v go &>/dev/null; then
  go_version=$(curl -sL https://go.dev/VERSION?m=text | head -1)
  curl -Lo /tmp/go.tar.gz "https://go.dev/dl/${go_version}.linux-amd64.tar.gz"
  sudo rm -rf /usr/local/go
  sudo tar -C /usr/local -xf /tmp/go.tar.gz
  echo 'export PATH=$PATH:/usr/local/go/bin' | sudo tee /etc/profile.d/go.sh
fi

# --- Rust ---
if ! command -v cargo &>/dev/null; then
  curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --no-modify-path
fi

# --- Poetry ---
if ! command -v poetry &>/dev/null; then
  curl -sSL https://install.python-poetry.org | python3 -
fi

# --- Docker ---
if ! command -v docker &>/dev/null; then
  curl -fsSL https://download.docker.com/linux/debian/gpg \
    | sudo gpg --dearmor -o /etc/apt/keyrings/docker.gpg
  echo \
    "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] \
    https://download.docker.com/linux/debian $(lsb_release -cs) stable" \
    | sudo tee /etc/apt/sources.list.d/docker.list
  sudo apt-get update -qq
  sudo apt-get install -y docker-ce docker-ce-cli containerd.io docker-compose-plugin
  sudo systemctl enable --now docker
  sudo usermod -aG docker "$USER"
fi

{{ end -}}
{{ end -}}
